# ── Base de datos (compartida entre Strapi y Postgres) ──
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=news_platform
DATABASE_USERNAME=news_platform_user
DATABASE_PASSWORD=cambiar-por-password-seguro
DATABASE_SSL=false

# ── Strapi: secrets (generar con `openssl rand -base64 32` cada uno) ──
APP_KEYS=clave1,clave2,clave3,clave4
API_TOKEN_SALT=cambiar
ADMIN_JWT_SECRET=cambiar
TRANSFER_TOKEN_SALT=cambiar
JWT_SECRET=cambiar

# ── Frontend: URL pública de Strapi (la que el NAVEGADOR puede resolver) ──
# Local:
NEXT_PUBLIC_STRAPI_URL=http://admin.newsplatform.local
# Producción (descomentar y usar en .env del VPS):
# NEXT_PUBLIC_STRAPI_URL=https://admin.tudominio.com
